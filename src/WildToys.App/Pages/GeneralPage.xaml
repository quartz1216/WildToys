<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WildToys.Pages.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="36,28,36,36" Spacing="20">
        <TextBlock Text="General" Style="{StaticResource TitleTextBlockStyle}" />

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="StartWithWindowsToggle"
                Header="Start with Windows"
                Toggled="StartWithWindowsToggle_Toggled" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="Launch WildToys automatically in the background when you sign in." />
        </StackPanel>

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="StartAsAdminToggle"
                Header="Start as administrator"
                Toggled="StartAsAdminToggle_Toggled" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="Run elevated so modules can interact with elevated windows (e.g. Task Manager). Takes effect on next launch." />
        </StackPanel>
    </StackPanel>
</Page>
