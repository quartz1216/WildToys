<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WildToys.SwitcherWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WildToys"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- The window is sized to fit this content; it never covers the screen. -->
    <Grid x:Name="RootGrid" Background="#1C1C1C">
        <Grid x:Name="ContentRoot"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="1100"
              MaxHeight="840">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Selected window title -->
            <TextBlock
                x:Name="ActiveWindowText"
                Grid.Row="0"
                Margin="24,20,24,16"
                HorizontalAlignment="Center"
                MaxWidth="640"
                FontSize="14"
                Foreground="White"
                TextTrimming="CharacterEllipsis" />

            <!-- Live DWM thumbnail anchor -->
            <Border
                Grid.Row="1"
                Background="#242424"
                BorderBrush="#191919"
                BorderThickness="0,1,0,1">
                <Grid Margin="24,16">
                    <Border
                        x:Name="ThumbnailAnchor"
                        Width="600"
                        Height="360"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        CornerRadius="4" />
                </Grid>
            </Border>

            <!-- Workspace rows (desktop label + window icons) -->
            <ScrollViewer
                Grid.Row="2"
                Margin="24,16,24,20"
                MaxHeight="360"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="RowsPanel" Orientation="Vertical" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
