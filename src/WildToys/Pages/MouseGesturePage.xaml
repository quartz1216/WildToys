<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WildToys.Pages.MouseGesturePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WildToys.Pages">
    <ScrollViewer>
        <StackPanel Margin="36,28,36,36" Spacing="20" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="MouseGesture" Style="{StaticResource TitleTextBlockStyle}" />

            <StackPanel Spacing="4">
                <ToggleSwitch
                    x:Name="EnabledToggle"
                    Header="Enable MouseGesture"
                    Toggled="EnabledToggle_Toggled" />
                <TextBlock
                    Opacity="0.6"
                    FontSize="12"
                    TextWrapping="Wrap"
                    Text="Hold the gesture button and drag in 4-direction strokes (chainable, e.g. → ← ↑) to fire a shortcut. Assign a process to limit a gesture to that app; leave it empty to apply everywhere." />
            </StackPanel>

            <Button x:Name="AddButton" Content="Add gesture" Click="AddButton_Click" />

            <ListView
                x:Name="EntriesList"
                SelectionMode="None"
                IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:GestureItem">
                        <Grid Padding="12,10" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{x:Bind Arrows}" FontSize="18" />
                                <TextBlock Text="{x:Bind Detail}" Opacity="0.6" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Content="Edit"
                                Tag="{x:Bind}"
                                Click="EditButton_Click" />
                            <Button
                                Grid.Column="2"
                                Content="Delete"
                                Tag="{x:Bind}"
                                Click="DeleteButton_Click" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                x:Name="EmptyHint"
                Opacity="0.5"
                FontSize="12"
                Text="No gestures yet. Click Add gesture to create one." />
        </StackPanel>
    </ScrollViewer>
</Page>
