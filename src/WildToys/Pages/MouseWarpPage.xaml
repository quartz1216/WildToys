<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WildToys.Pages.MouseWarpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="36,28,36,36" Spacing="20" MaxWidth="640" HorizontalAlignment="Left">
        <TextBlock Text="MouseWarp" Style="{StaticResource TitleTextBlockStyle}" />

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="EnabledToggle"
                Header="Enable MouseWarp"
                Toggled="EnabledToggle_Toggled" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="When you switch to a window with the keyboard (Alt+Tab or the Power Switcher), the cursor jumps to the center of that window. Activating a window by clicking it leaves the cursor where it is." />
        </StackPanel>

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="AnimationToggle"
                Header="Animate the cursor"
                Toggled="AnimationToggle_Toggled" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="Glide the cursor to the center with an ease-out motion instead of jumping there instantly." />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock x:Name="DurationLabel" Text="Animation duration: 180 ms" FontWeight="SemiBold" />
            <Slider
                x:Name="DurationSlider"
                Minimum="40"
                Maximum="600"
                StepFrequency="20"
                Value="180"
                ValueChanged="DurationSlider_ValueChanged" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="How long the glide takes. Only used when the animation is enabled." />
        </StackPanel>
    </StackPanel>
</Page>
