<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WildToys.Pages.ImIndicatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="36,28,36,36" Spacing="20" MaxWidth="640" HorizontalAlignment="Left">
        <TextBlock Text="IM Indicator" Style="{StaticResource TitleTextBlockStyle}" />

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="EnabledToggle"
                Header="Enable IM Indicator"
                Toggled="EnabledToggle_Toggled" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="When the input language changes (e.g. Win+Space to switch between a US and a Japanese keyboard), a small badge with the language name appears just below the text caret and fades away on its own." />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock x:Name="DurationLabel" Text="Display time: 1500 ms" FontWeight="SemiBold" />
            <Slider
                x:Name="DurationSlider"
                Minimum="500"
                Maximum="4000"
                StepFrequency="100"
                Value="1500"
                ValueChanged="DurationSlider_ValueChanged" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="How long the badge stays on screen after the language changes." />
        </StackPanel>

        <TextBlock
            Opacity="0.6"
            FontSize="12"
            TextWrapping="Wrap"
            Text="Note: the badge follows the text caret in apps that expose one. Some apps (e.g. Chromium-based browsers) don't, so it falls back to appearing just below the mouse cursor." />
    </StackPanel>
</Page>
