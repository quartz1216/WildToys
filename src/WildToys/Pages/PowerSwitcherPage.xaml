<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WildToys.Pages.PowerSwitcherPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="36,28,36,36" Spacing="20">
        <TextBlock Text="Power Switcher" Style="{StaticResource TitleTextBlockStyle}" />

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="EnabledToggle"
                Header="Enable Power Switcher"
                Toggled="EnabledToggle_Toggled" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="A fast, minimalist replacement for Alt+Tab that groups windows by virtual desktop and shows a live preview. Formerly &quot;BWS&quot;." />
        </StackPanel>

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="DimToggle"
                Header="Dim the background"
                Toggled="DimToggle_Toggled" />
            <TextBlock x:Name="DimAmountLabel" Opacity="0.8" FontSize="12" Text="Darkness: 35%" />
            <Slider
                x:Name="DimSlider"
                Minimum="0"
                Maximum="100"
                StepFrequency="5"
                Value="35"
                ValueChanged="DimSlider_ValueChanged" />
        </StackPanel>

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="BlurToggle"
                Header="Blur the background"
                Toggled="BlurToggle_Toggled" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="Acrylic blur of the desktop behind the switcher. Combine it with the dim above — the darkness slider also tints the blur." />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock x:Name="DelayLabel" Text="Show delay: 50 ms" FontWeight="SemiBold" />
            <Slider
                x:Name="DelaySlider"
                Minimum="0"
                Maximum="400"
                StepFrequency="10"
                Value="50"
                ValueChanged="DelaySlider_ValueChanged" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="How long to wait before the switcher appears. A quick Alt+Tab tap switches to the previous window without showing the UI." />
        </StackPanel>

        <StackPanel Spacing="4">
            <ToggleSwitch
                x:Name="FadeToggle"
                Header="Fade in the background"
                Toggled="FadeToggle_Toggled" />
            <TextBlock
                Opacity="0.6"
                FontSize="12"
                TextWrapping="Wrap"
                Text="Animate the dim/blur backdrop and the switcher fading in when it appears." />
        </StackPanel>

        <StackPanel Spacing="2">
            <TextBlock Text="Shortcuts" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Opacity="0.6" FontSize="12" Text="Alt+Tab — open and step forward (hold Alt)" />
            <TextBlock Opacity="0.6" FontSize="12" Text="Arrow keys / hjkl — move selection" />
            <TextBlock Opacity="0.6" FontSize="12" Text="Release Alt or Enter — switch to the selected window" />
            <TextBlock Opacity="0.6" FontSize="12" Text="Q or middle-click — close the selected window" />
            <TextBlock Opacity="0.6" FontSize="12" Text="Esc — cancel" />
        </StackPanel>
    </StackPanel>
</Page>
