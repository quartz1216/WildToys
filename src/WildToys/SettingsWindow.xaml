<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WildToys.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WildToys"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WildToys"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Grid.Row="0" Title="WildToys" />

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="190"
            CompactModeThresholdWidth="0"
            ExpandedModeThresholdWidth="0"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavGeneral" Content="General" Tag="GeneralPage" />
                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Modules" />
                <NavigationViewItem Content="MouseWarp" Tag="MouseWarpPage" />
                <NavigationViewItem Content="Power Switcher" Tag="PowerSwitcherPage" />
                <NavigationViewItem Content="LumaEdges" Tag="LumaEdgesPage" />
                <NavigationViewItem Content="MouseGesture" Tag="MouseGesturePage" />
                <NavigationViewItem Content="IM Indicator" Tag="ImIndicatorPage" />
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
